# Generated by Cargo
# will have compiled files and executables
/debug
/target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# Generated by Visual Studio Code
.vscode

# Configuration file containing the API key, which should not be committed to version control
config.toml

# Local database file storing cached data
/data/*
!/data/proxy_events/

# Directory for experiment runs, which may contain large files and should not be committed
/runs
/runs_test